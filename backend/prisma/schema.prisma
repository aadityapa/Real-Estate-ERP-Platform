/// PropOS SaaS subscription (tenant → STARTER/GROWTH/ENTERPRISE). Money in integer paise.
model Subscription {
  id                     String             @id @default(cuid())
  tenantId               String
  plan                   PlanType
  status                 SubStatus          @default(TRIAL)
  billingCycle           BillingCycle       @default(MONTHLY)
  /// Recurring amount in integer paise (INR).
  amountPaise            BigInt
  currency               String             @default("INR")
  /// MRR contribution in paise (normalized monthly; yearly / 12).
  mrrPaise               BigInt             @default(0)
  provider               GatewayProvider    @default(RAZORPAY)
  providerSubscriptionId String?            @unique
  providerPlanId         String?
  startDate              DateTime           @default(now())
  endDate                DateTime?
  trialEndsAt            DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  cancelAtPeriodEnd      Boolean            @default(false)
  cancelledAt            DateTime?
  /// Dunning: NONE | RETRYING | EXHAUSTED
  dunningStatus          String             @default("NONE")
  dunningAttempts        Int                @default(0)
  lastPaymentAt          DateTime?
  nextRetryAt            DateTime?
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id])
  invoices SaasInvoice[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([status])
}

/// PropOS SaaS invoice. Amounts in integer paise. GST detail on linked GSTInvoice.
model SaasInvoice {
  id                 String            @id @default(cuid())
  tenantId           String
  subscriptionId     String
  invoiceNumber      String            @unique
  /// Integer paise (INR) — gross inclusive of GST when GST invoice linked.
  amountPaise        BigInt
  currency           String            @default("INR")
  status             SaasInvoiceStatus @default(OPEN)
  periodStart        DateTime
  periodEnd          DateTime
  providerInvoiceId  String?           @unique
  providerPaymentId  String?
  /// Human note; structured GST lives on GSTInvoice.
  taxNote            String?
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  subscription Subscription @relation(fields: [subscriptionId], references: [id])
  gstInvoice   GSTInvoice?

  @@index([tenantId])
  @@index([subscriptionId])
  @@index([tenantId, status])
}

