// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ MULTI-TENANCY ============

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  domain    String?  @unique
  logo      String?
  plan      PlanType @default(STARTER)
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies       Company[]
  subscriptions   Subscription[]
  users           User[]
  roles           Role[]
  lmsGoals        LmsGoal[]
  clashLeads      ClashLead[]
  tabLoginConfigs TabLoginConfig[]
  helpdeskTickets HelpdeskTicket[]
  daReports       DaReport[]
  appointments    Appointment[]
  customers         Customer[]
  auditLogs         AuditLog[]
  limits            TenantLimits?
  gatewayPayments   GatewayPayment[]
  gatewayRefunds    GatewayRefund[]
  gatewayWebhookEvents GatewayWebhookEvent[]
  saasInvoices      SaasInvoice[]
  gstInvoices       GSTInvoice[]
  tdsEntries        TdsEntry[]
  reraProfiles      ReraProjectProfile[]
  reraPaymentStages ReraPaymentStage[]
  agreementTemplates AgreementTemplate[]
  eSignRequests     ESignRequest[]
}

/// Per-tenant limit overrides (null fields fall back to plan defaults). Basis for Phase 5 billing.
model TenantLimits {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  /// Max authenticated API requests per minute for this tenant.
  apiRateLimitRpm  Int?
  /// Max active user seats (status=ACTIVE).
  maxSeats         Int?
  /// Max projects (via Company) for this tenant. -1 = unlimited.
  maxProjects      Int?
  /// Max document storage in bytes (sum of Document.fileSize).
  maxStorageBytes  BigInt?
  /// Max concurrent BullMQ jobs for this tenant.
  queueConcurrency Int?
  /// Optional feature-flag overrides (string keys → bool). Null keys fall back to plan.
  featureFlags     Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

/// Append-only security audit trail. Diffs store field names + value hashes only (never raw PII).
model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  actorId       String?
  action        String
  entity        String
  entityId      String?
  /// SHA-256 over sorted "field:valueHash" pairs of prior state (omit on create).
  beforeHash    String?
  /// SHA-256 over sorted "field:valueHash" pairs of new state / request body.
  afterHash     String?
  changedFields String[] @default([])
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, entityId])
  @@index([actorId])
}

model Company {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  gstin     String?
  /// GST state code (2 digits). Derived from GSTIN when omitted.
  stateCode String?
  pan       String?
  rera      String?
  logo      String?
  address   Json?
  status    Status   @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  projects    Project[]
  branches    Branch[]
  employees   Employee[]
  gstInvoices GSTInvoice[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model Project {
  id          String        @id @default(cuid())
  companyId   String
  name        String
  code        String        @unique
  type        ProjectType
  status      ProjectStatus @default(PLANNING)
  location    Json?
  reraNumber  String?
  startDate   DateTime?
  expectedEnd DateTime?
  totalUnits  Int           @default(0)
  totalArea   Decimal?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  company              Company               @relation(fields: [companyId], references: [id])
  towers               Tower[]
  buildings            Building[]
  units                Unit[]
  milestones           Milestone[]
  leads                Lead[]
  boqs                 BOQ[]
  paymentPlans         PaymentPlan[]
  siteVisits           SiteVisit[]
  dailyProgressReports DailyProgressReport[]
  qualityChecks        QualityCheck[]
  vendorContracts      VendorContract[]
  purchaseRequisitions PurchaseRequisition[]
  purchaseOrders       PurchaseOrder[]
  inventoryItems       InventoryItem[]
  budgets              Budget[]
  lmsGoals             LmsGoal[]
  ypsrReports          YpsrReport[]
  reraProfile          ReraProjectProfile?
  reraPaymentStages    ReraPaymentStage[]

  @@index([status])
  @@index([createdAt])
}

model Branch {
  id        String  @id @default(cuid())
  companyId String
  name      String
  address   Json?
  phone     String?
  email     String?
  status    Status  @default(ACTIVE)

  company   Company    @relation(fields: [companyId], references: [id])
  employees Employee[]
}

// ============ USER & AUTH ============

model User {
  id           String    @id @default(cuid())
  tenantId     String
  employeeId   String?   @unique
  email        String    @unique
  phone        String?
  passwordHash String
  firstName    String
  lastName     String
  avatar       String?
  status       Status    @default(ACTIVE)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  employee        Employee?        @relation(fields: [employeeId], references: [id])
  roles           UserRole[]
  sessions        Session[]
  notifications   Notification[]
  assignedLeads   Lead[]           @relation("AssignedTo")
  claimedLeads    Lead[]           @relation("ClaimedBy")
  activities      Activity[]
  followUps       FollowUp[]
  callLogs        CallLog[]
  meetings        Meeting[]
  appointments    Appointment[]
  lmsGoals        LmsGoal[]
  raisedTickets   HelpdeskTicket[] @relation("TicketRaisedBy")
  assignedTickets HelpdeskTicket[] @relation("TicketAssignedTo")
  ticketReplies   TicketReply[]
  daReports       DaReport[]

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
}

model Role {
  id          String  @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean @default(false)

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  users           UserRole[]
  permissions     RolePermission[]
  tabLoginConfigs TabLoginConfig[]

  @@index([tenantId])
}

model Permission {
  id       String @id @default(cuid())
  module   String
  action   String
  resource String

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  /// Shared across refresh rotations; reuse of a revoked token revokes the whole family.
  familyId     String
  token        String    @unique
  refreshToken String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
}

// ============ EMPLOYEE / HRMS ============

model Employee {
  id            String         @id @default(cuid())
  companyId     String
  branchId      String?
  employeeCode  String         @unique
  firstName     String
  lastName      String
  email         String         @unique
  phone         String
  designation   String?
  department    String?
  dateOfJoining DateTime?
  dateOfBirth   DateTime?
  gender        Gender?
  address       Json?
  documents     Json?
  /// AES-256-GCM ciphertext string inside Json (enc:v1:…) via Prisma PII extension.
  bankDetails   Json?
  salary        Decimal?
  status        EmployeeStatus @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company    Company      @relation(fields: [companyId], references: [id])
  branch     Branch?      @relation(fields: [branchId], references: [id])
  user       User?
  attendance Attendance[]
  leaves     Leave[]
  payslips   Payslip[]
  expenses   Expense[]

  @@index([status])
  @@index([createdAt])
}

model Attendance {
  id         String           @id @default(cuid())
  employeeId String
  date       DateTime         @db.Date
  checkIn    DateTime?
  checkOut   DateTime?
  status     AttendanceStatus
  notes      String?

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Leave {
  id           String         @id @default(cuid())
  employeeId   String
  type         LeaveType
  startDate    DateTime       @db.Date
  endDate      DateTime       @db.Date
  days         Int
  reason       String?
  status       ApprovalStatus @default(PENDING)
  approvedById String?
  createdAt    DateTime       @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Payslip {
  id          String        @id @default(cuid())
  employeeId  String
  month       Int
  year        Int
  basicSalary Decimal
  allowances  Json?
  deductions  Json?
  grossSalary Decimal
  netSalary   Decimal
  status      PayslipStatus @default(GENERATED)
  paidAt      DateTime?

  employee Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id           String          @id @default(cuid())
  employeeId   String
  category     ExpenseCategory
  amount       Decimal
  description  String?
  receipt      String?
  date         DateTime        @db.Date
  status       ApprovalStatus  @default(PENDING)
  approvedById String?
  createdAt    DateTime        @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
}

// ============ CRM ============

model Lead {
  id              String         @id @default(cuid())
  tenantId        String
  projectId       String?
  assignedToId    String?
  source          LeadSource
  status          LeadStatus     @default(NEW)
  priority        Priority       @default(MEDIUM)
  score           Int            @default(0)
  firstName       String
  lastName        String?
  email           String?
  phone           String
  alternatePhone  String?
  budget          Json?
  requirements    Json?
  location        String?
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  referredById    String?
  aiScore         Int?
  aiNotes         String?
  aiNextAction    String?
  leadLabel       LeadLabel      @default(WARM)
  leadCallStatus  LeadCallStatus @default(PENDING)
  leadRat         Int            @default(0)
  description     String?
  claimedById     String?
  claimedAt       DateTime?
  claimReleasedAt DateTime?
  claimHistory    Json?
  feedScore       Int            @default(0)
  dismissReason   DismissReason?
  dismissNotes    String?
  isArchived      Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  project      Project?        @relation(fields: [projectId], references: [id])
  assignedTo   User?           @relation("AssignedTo", fields: [assignedToId], references: [id])
  claimedBy    User?           @relation("ClaimedBy", fields: [claimedById], references: [id])
  referredBy   ChannelPartner? @relation("ReferredBy", fields: [referredById], references: [id])
  followUps    FollowUp[]
  callLogs     CallLog[]
  siteVisits   SiteVisit[]
  meetings     Meeting[]
  activities   Activity[]
  appointments Appointment[]
  clashLeadsA  ClashLead[]     @relation("ClashLeadA")
  clashLeadsB  ClashLead[]     @relation("ClashLeadB")
  booking      Booking?

  @@index([tenantId])
  @@index([status])
  @@index([createdAt])
  @@index([assignedToId])
  @@index([claimedById])
  @@index([leadLabel])
}

model FollowUp {
  id           String         @id @default(cuid())
  leadId       String
  userId       String
  type         FollowUpType
  scheduledAt  DateTime
  completedAt  DateTime?
  notes        String?
  outcome      String?
  nextFollowUp DateTime?
  status       FollowUpStatus @default(SCHEDULED)
  createdAt    DateTime       @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model CallLog {
  id        String        @id @default(cuid())
  leadId    String
  userId    String
  direction CallDirection
  duration  Int?
  status    CallStatus
  notes     String?
  recording String?
  calledAt  DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

model SiteVisit {
  id          String            @id @default(cuid())
  leadId      String
  projectId   String
  scheduledAt DateTime
  completedAt DateTime?
  attendedBy  String?
  feedback    String?
  outcome     SiteVisitOutcome?
  status      VisitStatus       @default(SCHEDULED)
  createdAt   DateTime          @default(now())

  lead       Lead        @relation(fields: [leadId], references: [id])
  project    Project     @relation(fields: [projectId], references: [id])
  ypsrReport YpsrReport?
}

// ============ LMS MODULE ============

model TabLoginConfig {
  id          String   @id @default(cuid())
  tenantId    String
  roleId      String
  tabId       String   @unique
  label       String
  allowedTabs String[]
  defaultTab  String
  theme       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@index([tenantId])
  @@index([roleId])
}

model LmsGoal {
  id               String   @id @default(cuid())
  tenantId         String
  projectId        String
  userId           String?
  teamId           String?
  month            Int
  year             Int
  targetEnquiries  Int      @default(0)
  targetSiteVisits Int      @default(0)
  targetBookings   Int      @default(0)
  targetRevenue    Decimal  @default(0) @db.Decimal(15, 2)
  createdById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  user    User?   @relation(fields: [userId], references: [id])

  @@unique([tenantId, projectId, userId, month, year])
  @@index([tenantId])
}

model ClashLead {
  id           String          @id @default(cuid())
  tenantId     String
  leadAId      String
  leadBId      String
  assignedToId String?
  status       ClashLeadStatus @default(PENDING)
  resolvedById String?
  resolvedAt   DateTime?
  notes        String?
  detectedAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  leadA  Lead   @relation("ClashLeadA", fields: [leadAId], references: [id])
  leadB  Lead   @relation("ClashLeadB", fields: [leadBId], references: [id])

  @@index([tenantId])
  @@index([status])
}

model YpsrReport {
  id                 String            @id @default(cuid())
  siteVisitId        String            @unique
  projectId          String
  visitDate          DateTime
  leadName           String
  salesPerson        String
  unitsShown         String[]
  amenitiesPresented String[]
  leadFeedback       String?
  interestLevel      YpsrInterestLevel
  objections         String[]
  priceOffered       Decimal?          @db.Decimal(15, 2)
  followUpDate       DateTime?
  followUpAction     String?
  outcome            YpsrOutcome
  photos             String[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  siteVisit SiteVisit @relation(fields: [siteVisitId], references: [id])
  project   Project   @relation(fields: [projectId], references: [id])

  @@index([projectId])
}

model Appointment {
  id          String            @id @default(cuid())
  tenantId    String
  leadId      String
  userId      String
  type        AppointmentType
  scheduledAt DateTime
  duration    Int?
  notes       String?
  status      AppointmentStatus @default(PENDING)
  projectName String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([scheduledAt])
  @@index([status])
}

model HelpdeskTicket {
  id           String          @id @default(cuid())
  ticketNumber String          @unique
  tenantId     String
  raisedById   String
  assignedToId String?
  subject      String
  description  String
  category     SupportCategory @default(OTHER)
  priority     Priority        @default(MEDIUM)
  module       String?
  screenshots  String[]
  status       TicketStatus    @default(OPEN)
  resolvedAt   DateTime?
  resolution   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id])
  raisedBy   User          @relation("TicketRaisedBy", fields: [raisedById], references: [id])
  assignedTo User?         @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  replies    TicketReply[]

  @@index([tenantId])
  @@index([raisedById])
  @@index([status])
}

model TicketReply {
  id          String   @id @default(cuid())
  ticketId    String
  userId      String
  message     String
  attachments String[]
  isInternal  Boolean  @default(false)
  createdAt   DateTime @default(now())

  ticket HelpdeskTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

model DaReport {
  id               String   @id @default(cuid())
  tenantId         String
  userId           String
  reportDate       DateTime @db.Date
  callsMade        Int      @default(0)
  leadsContacted   Int      @default(0)
  siteVisits       Int      @default(0)
  followUpsDone    Int      @default(0)
  newLeadsAssigned Int      @default(0)
  createdAt        DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([tenantId, userId, reportDate])
  @@index([tenantId])
  @@index([reportDate])
}

model Meeting {
  id          String        @id @default(cuid())
  leadId      String
  userId      String
  title       String
  scheduledAt DateTime
  duration    Int?
  location    String?
  meetingUrl  String?
  notes       String?
  outcome     String?
  status      MeetingStatus @default(SCHEDULED)
  createdAt   DateTime      @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

// ============ INVENTORY & SALES ============

model Tower {
  id            String @id @default(cuid())
  projectId     String
  name          String
  floors        Int
  unitsPerFloor Int?
  status        Status @default(ACTIVE)

  project Project @relation(fields: [projectId], references: [id])
  units   Unit[]
}

model Building {
  id        String @id @default(cuid())
  projectId String
  name      String
  floors    Int
  status    Status @default(ACTIVE)

  project Project @relation(fields: [projectId], references: [id])
  units   Unit[]
}

model Unit {
  id          String     @id @default(cuid())
  projectId   String
  towerId     String?
  buildingId  String?
  unitNumber  String
  type        UnitType
  floor       Int?
  bedrooms    Int?
  bathrooms   Int?
  area        Decimal
  carpetArea  Decimal?
  builtupArea Decimal?
  superArea   Decimal?
  facing      String?
  basePrice   Decimal
  totalPrice  Decimal
  premiums    Json?
  amenities   String[]
  status      UnitStatus @default(AVAILABLE)
  floor_plan  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  project  Project   @relation(fields: [projectId], references: [id])
  tower    Tower?    @relation(fields: [towerId], references: [id])
  building Building? @relation(fields: [buildingId], references: [id])
  booking  Booking?
}

model Booking {
  id             String        @id @default(cuid())
  bookingNumber  String        @unique
  leadId         String        @unique
  unitId         String        @unique
  customerId     String
  salesPersonId  String
  unitPrice      Decimal
  premiumAmount  Decimal       @default(0)
  discountAmount Decimal       @default(0)
  totalAmount    Decimal
  bookingAmount  Decimal
  bookingDate    DateTime
  paymentPlanId  String?
  status         BookingStatus @default(BOOKED)
  cancelledAt    DateTime?
  cancelReason   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  lead        Lead         @relation(fields: [leadId], references: [id])
  unit        Unit         @relation(fields: [unitId], references: [id])
  customer    Customer     @relation(fields: [customerId], references: [id])
  paymentPlan PaymentPlan? @relation(fields: [paymentPlanId], references: [id])
  payments         Payment[]
  agreement        Agreement?
  receipts         Receipt[]
  commissions      Commission[]
  gatewayPayments  GatewayPayment[]

  @@index([status])
  @@index([createdAt])
}

model PaymentPlan {
  id           String  @id @default(cuid())
  projectId    String
  name         String
  description  String?
  installments Json
  isActive     Boolean @default(true)

  project  Project   @relation(fields: [projectId], references: [id])
  bookings Booking[]
}

model Payment {
  id              String        @id @default(cuid())
  bookingId       String
  installmentName String
  dueDate         DateTime
  amount          Decimal
  paidAmount      Decimal       @default(0)
  paidDate        DateTime?
  paymentMode     PaymentMode?
  reference       String?
  status          PaymentStatus @default(PENDING)
  receiptId       String?
  createdAt       DateTime      @default(now())

  booking         Booking          @relation(fields: [bookingId], references: [id])
  receipt         Receipt?         @relation(fields: [receiptId], references: [id])
  gatewayPayments GatewayPayment[]
}

/// Razorpay (and future PayU/Stripe) order linked to a booking installment.
/// Amounts are integer paise (INR); never float.
model GatewayPayment {
  id                String               @id @default(cuid())
  tenantId          String
  bookingId         String
  /// Installment schedule row (`Payment.id`).
  paymentId         String
  provider          GatewayProvider      @default(RAZORPAY)
  /// Amount charged via gateway, integer paise.
  amountPaise       BigInt
  currency          String               @default("INR")
  status            GatewayPaymentStatus @default(CREATED)
  providerOrderId   String               @unique
  providerPaymentId String?              @unique
  receiptId         String?
  ledgerEntryId     String?
  /// Opaque correlation notes sent to the gateway (no card/UPI/PII).
  notes             Json?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  booking  Booking         @relation(fields: [bookingId], references: [id])
  payment  Payment         @relation(fields: [paymentId], references: [id])
  refunds  GatewayRefund[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([bookingId])
  @@index([paymentId])
  @@index([createdAt])
}

model GatewayRefund {
  id               String              @id @default(cuid())
  tenantId         String
  gatewayPaymentId String
  amountPaise      BigInt
  providerRefundId String              @unique
  status           GatewayRefundStatus @default(PENDING)
  reason           String?
  ledgerEntryId    String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id])
  gatewayPayment GatewayPayment @relation(fields: [gatewayPaymentId], references: [id])

  @@index([tenantId])
  @@index([gatewayPaymentId])
}

/// Idempotent webhook intake — dedupe by provider + event id. Payload stored as hash only.
model GatewayWebhookEvent {
  id          String          @id @default(cuid())
  tenantId    String?
  provider    GatewayProvider
  eventId     String
  eventType   String
  /// SHA-256 of raw body (never store full card/UPI payloads).
  payloadHash String
  status      GatewayWebhookStatus @default(PROCESSED)
  error       String?
  processedAt DateTime        @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@unique([provider, eventId])
  @@index([tenantId])
  @@index([processedAt])
}

model Receipt {
  id            String      @id @default(cuid())
  receiptNumber String      @unique
  bookingId     String
  amount        Decimal
  paymentMode   PaymentMode
  reference     String?
  date          DateTime
  pdfUrl        String?
  checksum      String? // SHA-256 of the generated PDF — integrity verification
  createdAt     DateTime    @default(now())

  booking  Booking   @relation(fields: [bookingId], references: [id])
  payments Payment[]
}

model Agreement {
  id               String          @id @default(cuid())
  agreementNumber  String          @unique
  bookingId        String          @unique
  type             AgreementType
  executedDate     DateTime?
  registrationDate DateTime?
  stampDuty        Decimal?
  registrationFee  Decimal?
  documentUrl      String?
  documentChecksum String? // SHA-256 of the generated PDF — integrity verification
  /// Document vault row (versioned PDF).
  documentId       String?
  templateId       String?
  /// Generation / re-merge version (mirrors Document.version when vault-linked).
  version          Int             @default(1)
  status           AgreementStatus @default(DRAFT)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  booking   Booking            @relation(fields: [bookingId], references: [id])
  document  Document?          @relation(fields: [documentId], references: [id])
  template  AgreementTemplate? @relation(fields: [templateId], references: [id])
  eSignRequests ESignRequest[]

  @@index([documentId])
  @@index([templateId])
}

/// RERA registration + statutory disclosure fields per project (Prompt 6.2).
model ReraProjectProfile {
  id                    String    @id @default(cuid())
  tenantId              String
  projectId             String    @unique
  /// Official RERA registration number (mirrors Project.reraNumber when set).
  reraNumber            String
  registrationDate      DateTime?
  validUntil            DateTime?
  promoterName          String?
  /// Declared project carpet area under RERA (sq.m).
  totalCarpetAreaSqm    Decimal?
  openParkingCount      Int?
  coveredParkingCount   Int?
  /// Flexible disclosure checklist / quarterly update payload (no PII).
  disclosures           Json?
  projectWebsiteUrl     String?
  lastDisclosureAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@index([tenantId])
  @@index([tenantId, reraNumber])
}

/// Max cumulative % of sale consideration collectible at each construction stage.
model ReraPaymentStage {
  id                   String   @id @default(cuid())
  tenantId             String
  projectId            String
  code                 String
  name                 String
  /// Max cumulative % in basis points (1000 = 10%, 10000 = 100%).
  maxCumulativePctBps  Int
  sortOrder            Int
  /// When true, this stage's cap applies (and later stages if also completed).
  isCompleted          Boolean  @default(false)
  /// Optional link to construction Milestone.name for auto-completion.
  linkedMilestoneName  String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])

  @@unique([projectId, code])
  @@index([tenantId])
  @@index([tenantId, projectId])
}

/// Template for Agreement to Sell / allotment letter merge → PDF.
model AgreementTemplate {
  id        String        @id @default(cuid())
  tenantId  String
  name      String
  type      AgreementType
  /// Body with {{placeholders}} (buyerName, projectName, unitNumber, …).
  bodyText  String
  isActive  Boolean       @default(true)
  version   Int           @default(1)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  agreements Agreement[]

  @@index([tenantId])
  @@index([tenantId, type, isActive])
}

/// E-signature request against a vault Document (and optional Agreement).
model ESignRequest {
  id                String          @id @default(cuid())
  tenantId          String
  documentId        String
  agreementId       String?
  provider          ESignProvider   @default(MOCK)
  providerRequestId String          @unique
  status            ESignStatus     @default(PENDING)
  signUrl           String?
  signedFileUrl     String?
  /// Signer display name only (avoid stacking PII with phone/email in logs).
  signerName        String?
  /// Optional contact for provider — not logged with other PII.
  signerEmail       String?
  completedAt       DateTime?
  lastWebhookAt     DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  document  Document   @relation(fields: [documentId], references: [id])
  agreement Agreement? @relation(fields: [agreementId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([documentId])
  @@index([agreementId])
}

