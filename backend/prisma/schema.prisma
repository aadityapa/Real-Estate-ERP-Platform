/// GST tax invoice (sales/purchase). Amounts in integer paise (INR).
model GSTInvoice {
  id                String         @id @default(cuid())
  tenantId          String
  companyId         String?
  /// Statutory number: PREFIX/FY/SEQ (unique per tenant).
  invoiceNumber     String
  type              InvoiceType
  status            InvoiceStatus  @default(DRAFT)
  /// Line items: [{description, hsnSac, quantity, unitPricePaise, taxablePaise, gstRateBps}]
  items             Json
  supplierGstin     String
  supplierStateCode String
  buyerGstin        String?
  buyerStateCode    String
  buyerName         String?
  placeOfSupply     String
  customerId        String?
  vendorId          String?
  /// Optional link to PropOS SaaS invoice (Phase 5.2).
  saasInvoiceId     String?        @unique
  /// Optional link to booking payment receipt (Phase 5.1).
  receiptId         String?
  taxablePaise      BigInt
  cgstPaise         BigInt         @default(0)
  sgstPaise         BigInt         @default(0)
  igstPaise         BigInt         @default(0)
  totalGstPaise     BigInt
  totalPaise        BigInt
  currency          String         @default("INR")
  invoiceDate       DateTime
  dueDate           DateTime?
  /// e.g. "2025-26"
  fiscalYear        String
  seriesPrefix      String         @default("INV")
  /// GST e-invoice (IRN / signed QR) via pluggable IRP adapter.
  irn               String?        @unique
  irnAckNo          String?
  irnAckDate        DateTime?
  signedQr          String?
  eInvoiceStatus    EInvoiceStatus @default(NOT_APPLICABLE)
  eInvoiceProvider  String?
  eInvoiceError     String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  company     Company?     @relation(fields: [companyId], references: [id])
  saasInvoice SaasInvoice? @relation(fields: [saasInvoiceId], references: [id])
  tdsEntries  TdsEntry[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, fiscalYear])
  @@index([tenantId, invoiceDate])
  @@index([eInvoiceStatus])
  @@index([createdAt])
}

/// TDS deduction / return row. Amounts in integer paise.
model TdsEntry {
  id                 String    @id @default(cuid())
  tenantId           String
  /// IT section e.g. 194IA, 194C, 194J, 194Q
  section            String
  deducteeType       String
  deducteeName       String
  /// Last-4 or encrypted PAN reference — never log full PAN with name.
  deducteePanLast4   String?
  vendorId           String?
  customerId         String?
  vendorPaymentId    String?
  paymentId          String?
  gstInvoiceId       String?
  paymentAmountPaise BigInt
  /// Rate in basis points (100 = 1%).
  tdsRateBps         Int
  tdsAmountPaise     BigInt
  netPayablePaise    BigInt
  deductDate         DateTime
  challanNumber      String?
  challanDate        DateTime?
  /// Q1–Q4 of the Indian FY
  quarter            String
  fiscalYear         String
  status             TdsStatus @default(ACCRUED)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  gstInvoice GSTInvoice? @relation(fields: [gstInvoiceId], references: [id])

  @@index([tenantId])
  @@index([tenantId, fiscalYear, quarter])
  @@index([tenantId, section])
  @@index([tenantId, status])
  @@index([createdAt])
}

model VendorPayment {
  id          String      @id @default(cuid())
  vendorId    String
  poId        String?
  amount      Decimal
  paymentMode PaymentMode
  reference   String?
  paidDate    DateTime
  notes       String?
  createdBy   String
  createdAt   DateTime    @default(now())

