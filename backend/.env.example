# PropOS Backend — environment variables
# Copy to .env in this directory (backend)

NODE_ENV=development
HOST=0.0.0.0
PORT=3001

# Comma-separated browser origins allowed for CORS / WebSocket
# Example: http://localhost:3000,https://app.propos.in
CORS_ORIGINS=http://localhost:3000
# Or a single origin:
# FRONTEND_URL=http://localhost:3000

# Database (required)
DATABASE_URL=postgresql://propos:propos@localhost:5432/propos

# Redis (required for queues / cache)
REDIS_URL=redis://localhost:6379

# Auth (required)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# HMAC-SHA256 secret for signed /storage file URLs (falls back to JWT_SECRET)
STORAGE_URL_SECRET=change-me-storage-url-secret-long-random-string

# AES-256-GCM key for PII-at-rest (Customer PAN / Aadhaar-last-4, bank details).
# Use 32-byte value as base64 OR 64-char hex. Required in production.
PII_ENCRYPTION_KEY=change-me-pii-encryption-key-32-byte-base64-or-hex

# AWS (optional — document storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=propos-documents
AWS_CLOUDFRONT_URL=

# AI (optional)
OPENAI_API_KEY=

# WhatsApp (optional)
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@propos.in

# SMS (optional)
SMS_API_KEY=
SMS_SENDER_ID=

# GST / e-invoicing (Phase 6.1) — see docs/GST_EINVOICING.md
# IRP adapter: mock (default sandbox) | gsp (licensed GSP stub until wired)
GST_IRP_PROVIDER=mock
GST_AUTO_EINVOICE=true
# PropOS-as-supplier GSTIN for SaaS tax invoices (links SaasInvoice → GSTInvoice)
PROPOS_SUPPLIER_GSTIN=
PROPOS_SUPPLIER_STATE_CODE=
PROPOS_DEFAULT_BUYER_STATE=
# Licensed GSP credentials (required when GST_IRP_PROVIDER=gsp in production)
GST_GSP_API_KEY=
GST_GSP_BASE_URL=
GST_GSP_CLIENT_ID=
GST_GSP_CLIENT_SECRET=
# Legacy placeholder
GST_API_KEY=

# ── E-sign (Phase 6.2 — Digio / Leegality / DocuSign) ──
# Provider: mock (default) | digio (falls back to mock if Digio keys missing)
ESIGN_PROVIDER=mock
ESIGN_WEBHOOK_SECRET=change-me-esign-webhook
# Public API base for provider webhook callbacks (include /api/v1)
PUBLIC_API_URL=http://localhost:3001/api/v1
# Digio (when ESIGN_PROVIDER=digio and keys set — stub until HTTP adapter wired)
DIGIO_CLIENT_ID=
DIGIO_CLIENT_SECRET=
DIGIO_BASE_URL=

# ── Razorpay (Phase 5.1 — customer booking payments) ──
# Dashboard: https://dashboard.razorpay.com/app/keys
# Webhook URL: POST /api/v1/sales/payments/gateway/webhook
# Events: payment.captured, payment.failed, refund.processed, order.paid
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Webhooks). Falls back to KEY_SECRET if empty.
RAZORPAY_WEBHOOK_SECRET=

# ── Razorpay Subscriptions (Phase 5.2 — PropOS SaaS billing) ──
# Webhook URL: POST /api/v1/billing/webhook
# Events: subscription.activated, subscription.charged, subscription.pending,
#   subscription.halted, subscription.cancelled, subscription.completed
# Optional pre-created plan ids (else created via API on first subscribe):
# RAZORPAY_PLAN_STARTER_MONTHLY=
# RAZORPAY_PLAN_STARTER_YEARLY=
# RAZORPAY_PLAN_GROWTH_MONTHLY=
# RAZORPAY_PLAN_GROWTH_YEARLY=
# RAZORPAY_PLAN_ENTERPRISE_MONTHLY=
# RAZORPAY_PLAN_ENTERPRISE_YEARLY=

# Optional Postgres RLS (Phase 3.1). Policies are installed by migration
# 20260723140000_tenant_rls_opt_in but stay no-op until the app sets
# app.propos_rls=on + app.tenant_id per request. Leave false until that hook ships.
POSTGRES_RLS_ENABLED=false

# Per-tenant limits (Phase 3.2) use REDIS_URL for rate counters + BullMQ fairness.
# Plan defaults live in code; overrides in TenantLimits (migration 20260723160000_tenant_limits).

# ── Observability (Phase 4.1) — all optional; unset = no-op in local dev ──

# Structured JSON logs (pino via nestjs-pino)
LOG_LEVEL=info

# OpenTelemetry → any OTLP collector (Jaeger / Tempo / Datadog agent)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=propos-api
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Prometheus scrape at GET /metrics (Bearer METRICS_TOKEN or ?token=)
METRICS_ENABLED=false
# METRICS_TOKEN=change-me-metrics-scrape-token

# Sentry or self-hosted GlitchTip (leave DSN empty to disable)
# SENTRY_DSN=
# SENTRY_ENABLED=true
# SENTRY_ENVIRONMENT=development
# SENTRY_RELEASE=propos-api@0.1.0
# SENTRY_TRACES_SAMPLE_RATE=0

# ── Backups / DR (Phase 4.3) — see docs/DR_RUNBOOK.md ──
# BACKUP_DIR=./backups
# BACKUP_RETENTION_DAYS=30
# BACKUP_PITR_DAYS=7
# AWS_S3_BACKUP_PREFIX=propos-backups/postgres
# S3_NONCURRENT_DAYS=90
# AUDIT_LOG_RETENTION_DAYS=2555
# Tenant erasure requires migration 20260723180000_audit_log_erasure_allow
