{
  "name": "propos",
  "version": "0.1.0",
  "private": true,
  "description": "PropOS — Enterprise Real Estate ERP Platform",
  "scripts": {
    "dev": "turbo dev --filter=@propos/web --filter=@propos/api",
    "dev:web": "pnpm --filter @propos/web dev",
    "dev:api": "pnpm --filter @propos/api dev",
    "build": "turbo build --filter=@propos/web --filter=@propos/api",
    "build:web": "pnpm --filter @propos/web build",
    "build:api": "pnpm --filter @propos/api build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @propos/api db:generate",
    "db:migrate": "pnpm --filter @propos/api db:migrate",
    "db:push": "pnpm --filter @propos/api db:push",
    "db:studio": "pnpm --filter @propos/api db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
