{
  "name": "propos",
  "version": "0.1.0",
  "private": true,
  "description": "PropOS — Enterprise Real Estate ERP Platform",
  "scripts": {
    "dev": "turbo dev --filter=@propos/frontend --filter=@propos/backend",
    "dev:frontend": "pnpm --filter @propos/frontend dev",
    "dev:backend": "pnpm --filter @propos/backend dev",
    "dev:web": "pnpm dev:frontend",
    "dev:api": "pnpm dev:backend",
    "build": "turbo build --filter=@propos/frontend --filter=@propos/backend",
    "build:frontend": "pnpm --filter @propos/frontend build",
    "build:backend": "pnpm --filter @propos/backend build",
    "build:web": "pnpm build:frontend",
    "build:api": "pnpm build:backend",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @propos/backend db:generate",
    "db:migrate": "pnpm --filter @propos/backend db:migrate",
    "db:push": "pnpm --filter @propos/backend db:push",
    "db:studio": "pnpm --filter @propos/backend db:studio",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
