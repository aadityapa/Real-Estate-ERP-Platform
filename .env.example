# Monorepo environment index
#
# Backend and frontend are fully separated. Each app has its own env file:
#   apps/api/.env.example  → copy to apps/api/.env
#   apps/web/.env.example  → copy to apps/web/.env.local
#
# Quick local setup:
#   cp apps/api/.env.example apps/api/.env
#   cp apps/web/.env.example apps/web/.env.local
#
# Start infrastructure (Postgres + Redis):
#   docker compose -f infrastructure/docker/docker-compose.yml up -d
#
# Run apps independently:
#   pnpm dev:api   # http://localhost:3001/api/v1
#   pnpm dev:web   # http://localhost:3000
#
# Or both together:
#   pnpm dev
