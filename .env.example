# App
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Database
DATABASE_URL=postgresql://propos:propos@localhost:5432/propos

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=propos-documents
AWS_CLOUDFRONT_URL=

# AI
OPENAI_API_KEY=

# WebSocket (optional override)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# WhatsApp
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=

# Twilio (Voice)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Kafka
KAFKA_BROKERS=localhost:9092

# Email
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@propos.in

# SMS
SMS_API_KEY=
SMS_SENDER_ID=

# GST
GST_API_KEY=
