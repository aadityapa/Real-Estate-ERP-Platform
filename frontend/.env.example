# PropOS Frontend — environment variables
# Copy to .env.local in this directory (frontend)

# Backend REST API (required)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Backend origin for static files (/storage) and PDF links (optional)
# Defaults to NEXT_PUBLIC_API_URL without /api/v1
# NEXT_PUBLIC_API_ORIGIN=http://localhost:3001

# Socket.IO server (optional — defaults to API origin)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Sentry / GlitchTip (optional — leave unset for local no-op)
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_SENTRY_ENABLED=true
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# NEXT_PUBLIC_SENTRY_RELEASE=propos-web@0.1.0
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0
# Server/edge can use SENTRY_DSN (falls back to NEXT_PUBLIC_SENTRY_DSN)
# SENTRY_DSN=
