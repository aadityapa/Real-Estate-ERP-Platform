# PropOS API — environment variables
# Copy to .env in this directory (apps/api)

NODE_ENV=development
PORT=3001

# Comma-separated browser origins allowed for CORS / WebSocket
# Example: http://localhost:3000,https://app.propos.in
CORS_ORIGINS=http://localhost:3000
# Or a single origin:
# FRONTEND_URL=http://localhost:3000

# Database (required)
DATABASE_URL=postgresql://propos:propos@localhost:5432/propos

# Redis (required for queues / cache)
REDIS_URL=redis://localhost:6379

# Auth (required)
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_REFRESH_SECRET=change-me-refresh-secret-long-random-string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# AWS (optional — document storage)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=propos-documents
AWS_CLOUDFRONT_URL=

# AI (optional)
OPENAI_API_KEY=

# WhatsApp (optional)
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=

# Twilio (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (optional)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@propos.in

# SMS (optional)
SMS_API_KEY=
SMS_SENDER_ID=

# GST (optional)
GST_API_KEY=
