# Copy values into cron / CI secrets for backup jobs (Phase 4.3).
# See docs/DR_RUNBOOK.md

BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
BACKUP_PITR_DAYS=7
# Optional: s3://bucket/prefix for offsite dumps
# AWS_S3_BACKUP_PREFIX=propos-backups/postgres
S3_NONCURRENT_DAYS=90
S3_ABORT_MULTIPART_DAYS=7
SCRATCH_DB=propos_restore
